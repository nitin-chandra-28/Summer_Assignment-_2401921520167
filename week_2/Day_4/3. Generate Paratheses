class Solution {
    public List<String> generateParenthesis(int n) {
        List<String> result = new ArrayList<>();
        generate(0, "", 0, 0, n, result);
        return result;
    }

        //your code goes here
        private void generate(int index, String s, int open , int close , int n, List<String> result) {
            if(open > n) return;
            if(open + close == 2 * n && open == close) {
                result.add(s);
                return;
            }
            generate(index + 1, s + '(', open + 1, close, n, result);
            if(open > close) {
                generate(index + 1, s + ')', open, close + 1, n, result);
            }
        }
    }
