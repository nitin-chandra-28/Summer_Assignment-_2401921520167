import java.util.*;
class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int n = nums.length;
        int maxi = Integer.MIN_VALUE;
        for(int i = 0; i <= n - k; i++) {
            int sum = 0;
            for(int j = i; j < i + k; j++) {
                sum += nums[j];

            }
            if(sum > maxi) {
                maxi = sum;
            }
        }
        return (double)maxi/k;

    }
     public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter size of array: ");
        int n = sc.nextInt();
        int[] nums = new int[n];
        System.out.println("Length of subarray");
        int k = sc.nextInt();

        System.out.println("Enter array elements:");
        for (int i = 0; i < n; i++) {
            nums[i] = sc.nextInt();
        }
        Solution obj = new Solution();
        double result = obj.findMaxAverage(nums, k);

        System.out.println("Mximum Average Subarray" + result);

        sc.close();
    }
}
