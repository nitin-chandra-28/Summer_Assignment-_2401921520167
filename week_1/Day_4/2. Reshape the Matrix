class Solution {
    public int[][] matrixReshape(int[][] mat, int r, int c) {
        int n = mat.length;
        int m = mat[0].length;
        int l = m * n;
        int[] arr = new int[l];
        int newMat[][] = new int[r][c];

        if(m * n != r * c) {
            return mat;
        }
        for(int i = 0; i < n; i++) {
            for(int j = 0; j < m; j++) {
                arr[i * m + j] = mat[i][j];
            }
        }
        for(int i = 0; i < r; i++) {
            for(int j = 0; j < c; j++) {
                newMat[i][j] = arr[i * c + j];
            }
        }
        return newMat;
    }
}
