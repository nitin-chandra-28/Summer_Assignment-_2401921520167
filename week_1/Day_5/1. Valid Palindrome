class Solution {
    public boolean isPalindrome(String s) {

        String ans = s.toLowerCase().replaceAll("[^a-z0-9]", "");

        int left = 0;
        int right = ans.length() - 1;

        while(left < right) {
            if(ans.charAt(left) != ans.charAt(right)) {
                return false;
            }
            left++;
            right--;
        }
        return true;
    }
}
