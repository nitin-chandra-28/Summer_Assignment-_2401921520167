class Solution {
    public int maxArea(int[] height) {
        int h = height.length;
        int left = 0;
        int right = h - 1;
        int maxiArea = Integer.MIN_VALUE;

        while(left <= right) {
            int area = Math.min(height[left], height[right]) * (right - left);
            maxiArea = Math.max(area, maxiArea);
            if(height[left] < height[right]) {
                left++;
            } else {
                right--;
            }
        }
        return maxiArea;
    }
}
