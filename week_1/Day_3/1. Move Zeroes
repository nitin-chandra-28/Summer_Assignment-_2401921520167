class Solution {
    public void moveZeroes(int[] nums) {
        int n = nums.length;
        int[] temp = new int[n];
        int ind = 0;
        for(int i = 0; i < n; i++) {
            if(nums[i] != 0) {
                temp[ind++] = nums[i];
            }
        }
        int m = temp.length;
        for(int i = m; i < n; i++) {
            temp[ind++] = 0;
        }
        for(int i = 0; i < n; i++) {
            nums[i] = temp[i];
        }
    }
}
